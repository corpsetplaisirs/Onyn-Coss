<!-- ══ PAGE ACCOMPAGNEMENTS ══ -->
<div id="pg-accompagnements" class="page active sec" style="background:linear-gradient(180deg,var(--beige) 0%,var(--creme) 100%)">
  <div class="sh">
    <div class="stag">Séances</div>
    <h2 class="stitle">Mes <em>accompagnements</em></h2>
    <div class="sdiv"></div>
  </div>

  <div class="tgrid">
    <!-- Individuelle -->
    <div class="tc">
      <div class="tic">🌿</div>
      <div class="ttype">Consultation individuelle</div>
      <h3 class="tnom">Séance individuelle</h3>
      <div class="tprix">55<span> €</span></div>
      <p class="tdesc">Un espace personnel pour explorer vos questionnements, blocages ou curiosités autour de la sexualité et du désir.</p>
      <ul class="tlist">
        <li>Écoute bienveillante et sans jugement</li>
        <li>Approche psycho-sexologique</li>
        <li>Outils de pleine conscience</li>
      </ul>
      <a href="rendez-vous.html" class="tbtn">Réserver</a>
    </div>

    <!-- Couple (featured) -->
    <div class="tc feat">
      <div class="tic">💞</div>
      <div class="ttype">Consultation couple</div>
      <h3 class="tnom">Séance en couple</h3>
      <div class="tprix">90<span> €</span></div>
      <p class="tdesc">Pour traverser ensemble les difficultés relationnelles, améliorer la communication intime et renforcer votre complicité.</p>
      <ul class="tlist">
        <li>Thérapie de couple en sexo</li>
        <li>Communication intime</li>
        <li>Outils relationnels coconstruits</li>
      </ul>
      <a href="rendez-vous.html" class="tbtn">Réserver</a>
    </div>

    <!-- Étudiant -->
    <div class="tc">
      <div class="tic">🎓</div>
      <div class="ttype">Tarif solidaire</div>
      <h3 class="tnom">Séance étudiante</h3>
      <div class="tprix">45<span> €</span></div>
      <p class="tdesc">Parce que l'accès au soin ne devrait pas être un privilège. Sur justificatif étudiant valide.</p>
      <ul class="tlist">
        <li>Mêmes prestations (individuel)</li>
        <li>Justificatif étudiant requis</li>
        <li>Tarif accessible et bienveillant</li>
      </ul>
      <a href="rendez-vous.html" class="tbtn">Réserver</a>
    </div>
  </div>

  <p class="tnote">* Sur présentation d'une carte étudiante en cours de validité.</p>

  <!-- Politique d'annulation -->
  <div class="abox">
    <h4>⚖️ Politique de paiement &amp; d'annulation</h4>
    <div class="arow"><div class="aic a-ok">✅</div><p><strong>Paiement</strong> — Le règlement est à effectuer <strong>72h avant la séance</strong>, délais bancaires inclus. La confirmation du rendez-vous vaut acceptation de ces conditions.</p></div>
    <div class="arow"><div class="aic a-w">⏰</div><p><strong>Annulation plus de 48h avant</strong> — Annulation libre, sans frais.</p></div>
    <div class="arow"><div class="aic a-w">⚠️</div><p><strong>Annulation entre 48h et 0h</strong> — <strong>50 % du montant</strong> sera conservé à titre d'indemnité.</p></div>
    <div class="arow"><div class="aic a-e">🚫</div><p><strong>Absence ou annulation le jour J</strong> — <strong>L'intégralité du montant</strong> sera conservée.</p></div>
  </div>
</div>

